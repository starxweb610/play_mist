<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %><%= appName %> Admin</title>
  <meta name="robots" content="noindex, nofollow" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Admin CSS -->
  <link rel="stylesheet" href="/sitehandler/css/admin.css" />

  <%- typeof extraHead !== 'undefined' ? extraHead : '' %>
</head>
<body class="admin-body">

  <!-- ─── SIDEBAR ─────────────────────────────────────────────────────────── -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <span class="brand-icon">🎮</span>
      <div class="brand-text">
        <span class="brand-name"><%= appName %></span>
        <span class="brand-sub">Admin Panel</span>
      </div>
    </div>

    <nav class="sidebar-nav" aria-label="Admin navigation">
      <div class="nav-group">
        <span class="nav-group-label">Overview</span>
        <a href="/sitehandler/dashboard" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          <span>Dashboard</span>
        </a>
        <a href="/sitehandler/analytics" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'analytics' ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          <span>Analytics</span>
          <span class="nav-badge nav-badge--soon">Soon</span>
        </a>
      </div>

      <div class="nav-group">
        <span class="nav-group-label">Content</span>
        <a href="/sitehandler/games" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'games' ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 12h4M8 10v4M15 12h.01M18 12h.01M5 6h14a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2z"/></svg>
          <span>Games</span>
          <span class="nav-badge nav-badge--soon">Soon</span>
        </a>
      </div>

      <div class="nav-group">
        <span class="nav-group-label">Support</span>
        <a href="/sitehandler/tickets" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'tickets' ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 12V7a2 2 0 00-2-2H6a2 2 0 00-2 2v10a2 2 0 002 2h4m-4-5h8m-8-4h8"/><circle cx="18" cy="18" r="3"/><path d="M21 21l-1.5-1.5"/></svg>
          <span>Tickets</span>
          <span class="nav-badge nav-badge--soon">Soon</span>
        </a>
      </div>

      <div class="nav-group">
        <span class="nav-group-label">System</span>
        <a href="/sitehandler/admins" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'admins' ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          <span>Admins</span>
          <span class="nav-badge nav-badge--soon">Soon</span>
        </a>
        <a href="/sitehandler/settings" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'settings' ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
          <span>Settings</span>
          <span class="nav-badge nav-badge--soon">Soon</span>
        </a>
      </div>
    </nav>

    <div class="sidebar-footer">
      <div class="admin-info">
        <div class="admin-avatar"><%= admin && admin.name ? admin.name.charAt(0).toUpperCase() : 'A' %></div>
        <div class="admin-meta">
          <span class="admin-name"><%= admin ? admin.name : 'Admin' %></span>
          <span class="admin-role"><%= admin ? admin.role : 'root' %></span>
        </div>
      </div>
      <a href="/sitehandler/logout" class="logout-btn" title="Logout">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
      </a>
    </div>
  </aside>

  <!-- ─── MAIN AREA ─────────────────────────────────────────────────────── -->
  <div class="admin-main" id="adminMain">

    <!-- Topbar -->
    <header class="topbar">
      <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="topbar-page-title">
        <h1><%= typeof title !== 'undefined' ? title : 'Dashboard' %></h1>
      </div>
      <div class="topbar-actions">
        <a href="/" target="_blank" class="topbar-btn" title="View public site">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
          View Site
        </a>
      </div>
    </header>

    <!-- Flash Messages -->
    <% if (success_msg && success_msg.length > 0) { %>
      <div class="flash flash--success" role="alert">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <%= success_msg %>
        <button class="flash-close" aria-label="Dismiss">&times;</button>
      </div>
    <% } %>
    <% if (error_msg && error_msg.length > 0) { %>
      <div class="flash flash--error" role="alert">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <%= error_msg %>
        <button class="flash-close" aria-label="Dismiss">&times;</button>
      </div>
    <% } %>

    <!-- Page Content -->
    <main class="admin-content">
      <%- body %>
    </main>

  </div><!-- /admin-main -->

  <!-- Admin JS -->
  <script src="/sitehandler/js/admin.js"></script>
  <%- typeof extraScripts !== 'undefined' ? extraScripts : '' %>
</body>
</html>
